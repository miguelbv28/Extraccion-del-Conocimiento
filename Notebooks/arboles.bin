   "source": [
    "# Visualización del árbol entrenado\n",
    "plt.figure(figsize=(14, 8))\n",
    "plot_tree(\n",
    "    modelo,\n",
    "    feature_names=iris.feature_names,\n",
    "    class_names=modelo.classes_,\n",
    "    filled=True,\n",
    "    rounded=True,\n",
    "    fontsize=10\n",
    ")\n",
    "plt.title(\"Árbol de Decisión - Clasificación de especies de Iris\")\n",
    "plt.show()\n"
   ]
  },
