   "source": [
    "modelo = DecisionTreeClassifier(\n",
    "    criterion='gini',   # criterio de división\n",
    "    max_depth=3,         # profundidad máxima del árbol\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "modelo.fit(X_train, y_train)\n"
   ]
  },
