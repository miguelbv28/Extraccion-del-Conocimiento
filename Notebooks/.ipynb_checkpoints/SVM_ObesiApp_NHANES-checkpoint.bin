      ],
      "text/plain": [
       "    participant_id   age  gender  gender_code  weight_kg  height_cm   bmi  \\\n",
       "5         109270.0  11.0  female          2.0       75.3      156.0  30.9   \n",
       "10        109275.0   6.0    male          1.0       20.9      120.4  14.4   \n",
       "12        109277.0  12.0  female          2.0       48.7      162.0  18.6   \n",
       "13        109278.0   6.0  female          2.0       20.5      112.0  16.3   \n",
       "21        109287.0  11.0  female          2.0       40.4      145.1  19.2   \n",
       "\n",
       "    bmi_child_category risk_level  \n",
       "5                  4.0       alto  \n",
       "10                 2.0       bajo  \n",
       "12                 2.0       bajo  \n",
